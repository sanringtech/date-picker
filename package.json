{
  "name": "date-picker",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:docs": "ng serve docs",
    "build": "ng build",
    "build:docs": "ng build docs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "format": "prettier --write \"projects/**/*.{ts,html}\"",
    "format:check": "prettier --check \"projects/**/*.{ts,html}\"",
    "sync:theme": "bash scripts/sync-theme.sh",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "ng build date-picker && npm publish ./dist/date-picker --access public"
  },
  "private": true,
  "workspaces": ["projects/date-picker", "projects/date-picker-widget"],
  "packageManager": "npm@11.16.0",
  "dependencies": {
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@lucide/angular": "^1.23.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.6.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.6",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.2",
    "angular-eslint": "22.1.0",
    "axe-core": "^4.12.1",
    "eslint": "^10.6.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^22.0.0",
    "postcss": "^8.5.19",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "8.62.1",
    "vitest": "^4.0.8"
  }
}
